{
  "name": "visex",
  "displayName": "Visex — Profile Extension Manager",
  "description": "See and manage which extensions are installed in which VS Code profiles. No telemetry.",
  "version": "0.1.0",
  "publisher": "SamErde",
  "license": "MIT",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "extensionKind": ["ui"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      { "command": "visex.showMatrix", "title": "Visex: Show Extension Matrix", "icon": "$(extensions)" }
    ],
    "viewsContainers": {
      "activitybar": [{ "id": "visex", "title": "Visex", "icon": "media/visex.svg" }]
    },
    "views": { "visex": [{ "id": "visex.welcome", "name": "Profiles" }] },
    "viewsWelcome": [
      {
        "view": "visex.welcome",
        "contents": "Manage extensions across all your VS Code profiles.\n[Open Extension Matrix](command:visex.showMatrix)"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "npm run build && tsc -p tsconfig.integration.json && node out-test/test/integration/runTests.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "mocha": "^10.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
